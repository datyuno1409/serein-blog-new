# Netlify redirects file

# Admin area redirects - since PHP is not supported on Netlify
/admin/* /admin-not-available.html 200

# API redirects - since PHP is not supported on Netlify  
/api.php /api-not-available.html 200
/api/* /api-not-available.html 200

# Clean URL redirects for static pages
/home /index.html 200
/about /about.html 200
/portfolio /services.html 200
/blog /blog.html 200
/post /post.html 200

# Handle .html extension removal
/*.html /:splat 301

# Fallback for any other routes
/* /index.html 200