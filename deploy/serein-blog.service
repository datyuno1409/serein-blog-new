[Unit]
Description=Serein Blog Platform - FastAPI Application
After=network.target postgresql.service

[Service]
Type=simple
User=root
Group=root
WorkingDirectory=/var/www/serein-blog
Environment="PATH=/var/www/serein-blog/.venv/bin"
Environment="PYTHONPATH=/var/www/serein-blog"
ExecStart=/var/www/serein-blog/.venv/bin/uvicorn main:app --host 0.0.0.0 --port 8000 --workers 4
Restart=on-failure
RestartSec=5s

[Install]
WantedBy=multi-user.target
